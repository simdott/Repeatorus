@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix atom: <http://lv2plug.in/ns/ext/atom#> .
@prefix ui:   <http://lv2plug.in/ns/extensions/ui#> .
@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .
@prefix pprops: <http://lv2plug.in/ns/ext/port-props#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix param:  <http://lv2plug.in/ns/extensions/parameters#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix pg: <http://lv2plug.in/ns/ext/port-groups#> .

<urn:simdott:simondelaruotte>
    a foaf:Person ;
    foaf:name "Simon Delaruotte" ;
    foaf:homepage <https://github.com/simdott/repeatorus> .

<urn:simdott:repeatorus>
    a lv2:Plugin ;
    lv2:binary <repeatorus.so> ;
    doap:name "Repeatorus" ;
    doap:maintainer <urn:simdott:simondelaruotte> ;
    doap:license <http://spdx.org/licenses/GPL-2.0-or-later> ;
    doap:description "Stutter effect with optional MIDI controls." ;
    rdfs:label "Repeatorus" ;
    rdfs:comment "Repeatorus v1.0.1" ;
    lv2:optionalFeature lv2:hardRTCapable ;
    lv2:port [
        a lv2:InputPort, lv2:AudioPort ;
        lv2:index 0 ;
        lv2:symbol "input_l" ;
        lv2:name "Input L" ;
        rdfs:comment "Left channel audio input" ;
    ], [
        a lv2:InputPort, lv2:AudioPort ;
        lv2:index 1 ;
        lv2:symbol "input_r" ;
        lv2:name "Input R" ;
        rdfs:comment "Right channel audio input" ;
    ], [
        a lv2:OutputPort, lv2:AudioPort ;
        lv2:index 2 ;
        lv2:symbol "output_l" ;
        lv2:name "Output L" ;
        rdfs:comment "Left channel audio output" ;
    ], [
        a lv2:OutputPort, lv2:AudioPort ;
        lv2:index 3 ;
        lv2:symbol "output_r" ;
        lv2:name "Output R" ;
        rdfs:comment "Right channel audio output" ;
    ], [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 4 ;
        lv2:symbol "threshold_sens" ;
        lv2:name "Sensitivity" ;
        lv2:default 50.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 100.0 ;
        units:unit units:pc ;
        lv2:portProperty pprops:logarithmic ;
        rdfs:comment "0% = only loudest peaks trigger, 100% = very quiet sounds trigger" ;
    ], [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 5 ;
        lv2:symbol "time_master" ;
        lv2:name "Tempo" ;
        units:unit units:bpm ;
        lv2:default 120 ;
        lv2:minimum 60 ;
        lv2:maximum 300 ;
        rdfs:comment "Stutter length relative to tempo." ;        
    ], [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 6 ;
        lv2:symbol "bypass_1" ;
        lv2:name "1 beat" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
        lv2:portProperty lv2:toggled ;
        rdfs:comment "Enable/disable 1 beat stutter (full length)" ;        
    ], [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 7 ;
        lv2:symbol "bypass_2" ;
        lv2:name "1/8th" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
        lv2:portProperty lv2:toggled ;
        rdfs:comment "Enable/disable 1/8th stutter (half length)" ;
    ], [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 8 ;
        lv2:symbol "bypass_3" ;
        lv2:name "1/16th" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
        lv2:portProperty lv2:toggled ;
        rdfs:comment "Enable/disable 1/16 stutter (quarter length)" ;
    ], [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 9 ;
        lv2:symbol "bypass_4" ;
        lv2:name "1/32nd" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
        lv2:portProperty lv2:toggled ;
        rdfs:comment "Enable/disable 1/32nd stutter (eighth length)" ;
    ], [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 10 ;
        lv2:symbol "bypass_5" ;
        lv2:name "1/64th" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
        lv2:portProperty lv2:toggled ;
        rdfs:comment "Enable/disable 1/64th stutter (sixteenth length)" ;
    ], [
        a lv2:InputPort, atom:AtomPort ;
        lv2:index 11 ;
        lv2:symbol "midi_input" ;
        lv2:name "MIDI In" ;
        atom:bufferType atom:Sequence ;
        atom:supports <http://lv2plug.in/ns/ext/midi#MidiEvent> ;
        lv2:portProperty lv2:supportsMidi ;
        rdfs:comment "MIDI input for note-controlled stutter switching" ;
    ], [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 12 ;
        lv2:symbol "midi_switch" ;
        lv2:name "MIDI Control" ;
        lv2:default 0.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:portProperty lv2:toggled ;
        lv2:portProperty lv2:integer ;
        rdfs:comment "0 = use GUI buttons, 1 = use MIDI notes" ;
    ], [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 13 ;
        lv2:symbol "midi_channel" ;
        lv2:name "MIDI Channel" ;
        lv2:default 1.0 ;
        lv2:minimum 1.0 ;
        lv2:maximum 16.0 ;
        lv2:portProperty lv2:integer ;
        rdfs:comment "MIDI channel for note control (1-16)" ;
        lv2:scalePoint [ rdfs:label "1" ; rdf:value 1 ] ;
        lv2:scalePoint [ rdfs:label "2" ; rdf:value 2 ] ;
        lv2:scalePoint [ rdfs:label "3" ; rdf:value 3 ] ;
        lv2:scalePoint [ rdfs:label "4" ; rdf:value 4 ] ;
        lv2:scalePoint [ rdfs:label "5" ; rdf:value 5 ] ;
        lv2:scalePoint [ rdfs:label "6" ; rdf:value 6 ] ;
        lv2:scalePoint [ rdfs:label "7" ; rdf:value 7 ] ;
        lv2:scalePoint [ rdfs:label "8" ; rdf:value 8 ] ;
        lv2:scalePoint [ rdfs:label "9" ; rdf:value 9 ] ;
        lv2:scalePoint [ rdfs:label "10" ; rdf:value 10 ] ;
        lv2:scalePoint [ rdfs:label "11" ; rdf:value 11 ] ;
        lv2:scalePoint [ rdfs:label "12" ; rdf:value 12 ] ;
        lv2:scalePoint [ rdfs:label "13" ; rdf:value 13 ] ;
        lv2:scalePoint [ rdfs:label "14" ; rdf:value 14 ] ;
        lv2:scalePoint [ rdfs:label "15" ; rdf:value 15 ] ;
        lv2:scalePoint [ rdfs:label "16" ; rdf:value 16 ] ;
    ], [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 14 ;
        lv2:symbol "midi_note_1" ;
        lv2:name "1 beat  MIDI Note" ;
        lv2:default 60.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 127.0 ;
        lv2:portProperty lv2:integer ;
        units:unit units:midiNote ;
        rdfs:comment "MIDI note for 1 beat stutter toggle (0-127, C4=60)" ;
    ], [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 15 ;
        lv2:symbol "midi_note_2" ;
        lv2:name "1/8th   MIDI Note" ;
        lv2:default 61.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 127.0 ;
        lv2:portProperty lv2:integer ;
        units:unit units:midiNote ;
        rdfs:comment "MIDI note for 1/8th stutter toggle" ;
    ], [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 16 ;
        lv2:symbol "midi_note_3" ;
        lv2:name "1/16th  MIDI Note" ;
        lv2:default 62.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 127.0 ;
        lv2:portProperty lv2:integer ;
        units:unit units:midiNote ;
        rdfs:comment "MIDI note for 1/16th stutter toggle" ;
    ], [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 17 ;
        lv2:symbol "midi_note_4" ;
        lv2:name "1/32nd  MIDI Note" ;
        lv2:default 63.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 127.0 ;
        lv2:portProperty lv2:integer ;
        units:unit units:midiNote ;
        rdfs:comment "MIDI note for 1/32nd stutter toggle" ;
    ], [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 18 ;
        lv2:symbol "midi_note_5" ;
        lv2:name "1/64th  MIDI Note" ;
        lv2:default 64.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 127.0 ;
        lv2:portProperty lv2:integer ;
        units:unit units:midiNote ;
        rdfs:comment "MIDI note for 1/64th stutter toggle" ;
    ] .
